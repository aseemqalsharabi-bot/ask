rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global catch-all rule (Default Deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Products table: Publicly readable, writeable only by Admin
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // UI and Integration Settings: Publicly readable, writeable only by Admin
    match /settings/{settingId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Pages Content (About, Return Policy, etc.): Publicly readable, writeable only by Admin
    match /pages/{pageId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
